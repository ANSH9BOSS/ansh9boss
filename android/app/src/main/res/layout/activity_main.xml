<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- Minimal White Header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CheatsAnalyser"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DEVELOPED BY ANSH9BOSS"
        android:textColor="#A1A1AA"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Centered Scanning Radar SVG (Vector) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutRadar"
        android:layout_width="160dp"
        android:layout_height="160dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toTopOf="@id/layoutCurrentFile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <!-- Outer Ring Glow -->
        <View
            android:id="@+id/viewGlowRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/ic_launcher"
            android:alpha="0.15" />

        <!-- Rotating Radar Vector -->
        <ImageView
            android:id="@+id/ivScannerLogo"
            android:layout_width="135dp"
            android:layout_height="135dp"
            android:src="@drawable/ic_launcher"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Dedicate Status Box showing current file/folder/mod -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutCurrentFile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#09090B"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp">

        <!-- Thin white border logic via View or layout decoration -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#27272A"
            app:layout_constraintTop_toTopOf="parent" />
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#27272A"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvBoxTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCAN ENGINE STATUS"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvCurrentFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Idle. Waiting for folder link..."
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:ellipsize="middle"
            android:singleLine="true"
            app:layout_constraintTop_toBottomOf="@id/tvBoxTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Progress Indicator with clean white theme -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:indeterminate="false"
        android:visibility="invisible"
        android:progressDrawable="@android:drawable/progress_horizontal"
        android:progressTint="#FFFFFF"
        android:progressBackgroundTint="#27272A"
        app:layout_constraintBottom_toTopOf="@id/btnSelectFolder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- Action Buttons with minimal Black & White styling -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSelectFolder"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="LINK MODS DIRECTORY"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        app:backgroundTint="#000000"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="1.5dp"
        app:cornerRadius="4dp"
        app:layout_constraintBottom_toTopOf="@id/btnStartScan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartScan"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="START SYSTEM SCAN"
        android:textColor="#000000"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:enabled="false"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="4dp"
        app:layout_constraintBottom_toTopOf="@id/btnToggleDaemon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <!-- Background daemon observer switch button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggleDaemon"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="DAEMON GUARD: INACTIVE"
        android:textColor="#A1A1AA"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:backgroundTint="#09090B"
        app:strokeColor="#27272A"
        app:strokeWidth="1dp"
        app:cornerRadius="4dp"
        app:layout_constraintBottom_toTopOf="@id/scrollView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <!-- Minimal scrollable console -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:background="#09090B"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="System core initialized. Ready to execute...\n"
            android:textColor="#A1A1AA"
            android:textSize="10.5sp"
            android:lineSpacingExtra="2dp"/>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
