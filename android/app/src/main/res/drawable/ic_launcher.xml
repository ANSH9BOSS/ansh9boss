    <path
        android:strokeColor="#18181B"
        android:strokeWidth="0.5"
        android:pathData="M 0,10 L 100,10 M 0,20 L 100,20 M 0,30 L 100,30 M 0,40 L 100,40 M 0,50 L 100,50 M 0,60 L 100,60 M 0,70 L 100,70 M 0,80 L 100,80 M 0,90 L 100,90"/>

    <!-- Concentric radar circles matching website animated SVG -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:pathData="M 50,5 A 45,45 0 1,1 49.99,5 Z"
        android:fillColor="#00000000"
        android:strokeAlpha="0.3"/>
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.0"
        android:pathData="M 50,20 A 30,30 0 1,1 49.99,20 Z"
        android:fillColor="#00000000"
