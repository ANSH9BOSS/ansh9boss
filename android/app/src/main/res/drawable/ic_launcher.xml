        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.0"
        android:pathData="M 50,35 A 15,15 0 1,1 49.99,35 Z"
        android:fillColor="#00000000"
        android:strokeAlpha="0.1"/>

    <!-- Crosshair coordinate grid lines -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.75"
        android:strokeAlpha="0.2"
        android:pathData="M 50,5 L 50,95 M 5,50 L 95,50"/>

    <!-- Radar Sweep Hand Line pointing to target angle -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M 50,50 L 82,18"/>

    <!-- Radar Target Ping Dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 72,32 A 2.5,2.5 0 1, 1 71.99,32 Z"/>
