    <path
        android:strokeColor="#27272A"
        android:strokeWidth="1.5"
        android:pathData="M 20,10 L 80,10 L 90,40 L 50,90 L 10,40 Z"/>
    <!-- Outer white radar ring -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:pathData="M 50,15 A 35,35 0 1, 1 49.99,15 Z"/>
    <!-- Crosshairs -->
    <path
        android:strokeColor="#A1A1AA"
        android:strokeWidth="1.5"
        android:pathData="M 50,5 L 50,95 M 5,50 L 95,50"/>
    <!-- Center white core circle -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 50,42 A 8,8 0 1, 1 49.99,42 Z"/>
</vector>
